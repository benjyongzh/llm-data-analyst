# Shared settings for backend API and worker
LLM_API_KEY=sk-...
DATABASE_URL=postgresql://user:pass@localhost:5432/db
JWT_SECRET=change-me
JWT_EXP_SECONDS=86400
ENVIRONMENT=development
LLM_RESPONSE_MODEL=gpt-4o-mini
CONVERSATION_MEMORY_K=10
LOG_LEVEL=DEBUG
REDIS_URL=redis://localhost:6379/0
RUN_JWT_SECRET=change-me

# Backend API (Vercel)
FLY_WORKER_BASE_URL=https://worker.example.com
FLY_STREAM_BASE_URL=https://stream.example.com
